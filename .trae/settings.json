{
  "editor.tabSize": 2,
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": { "source.fixAll": true },
  "files.exclude": { "**/node_modules": true, "**/dist": true },
  "typescript.preferences.importModuleSpecifier": "relative",
  "editor.fontSize": 14,
  "editor.fontFamily": "'Fira Code', monospace",
  "editor.insertSpaces": true,
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,
  "assistant.defaultModel": "Claude Haiku 4.5",
  "assistant.codeModel": "Claude Haiku 4.5",
  "assistant.autoApplyChanges": false,
  "assistant.enableContext": true,
  "assistant.contextDepth": 5,
  "skills.enabled": [
    "nextjs-shadcn",
    "nextjs-code-review"
  ],
  "skills.disabled": [
    "git-commit"
  ]
}